{
  "name": "single-variable-mapper",
  "description": "GitHub Action to simplify variable remapping using regex patterns",
  "version": "0.0.0",
  "author": "caseycs",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/caseycs/single-variable-mapper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caseycs/single-variable-mapper.git"
  },
  "bugs": {
    "url": "https://github.com/caseycs/single-variable-mapper/issues"
  },
  "keywords": [
    "github-actions",
    "regex",
    "mapping",
    "deployment",
    "ci-cd",
    "variable-mapping",
    "environment"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=21"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npm run lint:eslint && npm run lint:md && npm run lint:yaml",
    "lint:eslint": "npx eslint . -c ./.github/linters/eslint.config.mjs",
    "lint:md": "npx markdownlint-cli2 --config .github/linters/.markdownlint.yml \"**/*.md\" \"!node_modules\" \"!dist\"",
    "lint:yaml": "npx yamllint \"**/*.{yml,yaml}\" -c .github/linters/.yaml-lint.yml -i \"node_modules/**\" -i \"dist/**\"",
    "local-action": "npx local-action . src/main.ts .env",
    "package": "npx esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --sourcemap",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0"
  },
  "devDependencies": {
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.26.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.21.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsonc": "^3.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "make-coverage-badge": "^1.2.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.6",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^5.9.3",
    "yaml-lint": "^1.7.0"
  }
}
